{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug Gemini Audio Output Test",
            "type": "go",
            "request": "launch",
            "mode": "test",
            "program": "${workspaceFolder}/runtime/providers/gemini",
            "args": [
                "-test.run",
                "TestDiagnostic_AudioModalityRawMessages",
                "-test.v",
                "-test.timeout",
                "60s"
            ],
            "buildFlags": "-tags=integration",
            "cwd": "${workspaceFolder}/runtime/providers/gemini",
            "env": {
            },
            "console": "integratedTerminal",
            "showLog": true
        }
    ]
}
