# Binaries
*.exe
*.exe~
*.dll
*.so
*.dylib
bin/
dist/

# Generated files
schemas/*
!schemas/v1alpha1/
schemas/v1alpha1/*
!schemas/v1alpha1/*.json
!schemas/v1alpha1/common/
schemas/v1alpha1/common/*
!schemas/v1alpha1/common/*.json

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool
*.out
coverage.out
coverage.html
lcov.info

# SonarQube analysis files
sonar-issues.txt
sonar-report.json
golangci-lint-report.json

# Go workspace file
go.work.sum

