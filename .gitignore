docs/superpowers

# Documentation (Astro)
docs/dist/
docs/.astro/
docs/node_modules/
docs/src/content/api/
docs/src/content/sdk/examples/
docs/src/content/reference/*-cli.txt
docs/public/schemas/

# Jekyll backup (legacy)
docs-jekyll-backup/

packs/

/promptpack-spec/

# Ignore built binaries
/evaluate
commit-msg.txt

# SDK examples: ignore everything except .go, .md, and go.mod/go.sum files
sdk/examples/**/*
!sdk/examples/**/*.go
!sdk/examples/**/*.md
!sdk/examples/**/*.json
!sdk/examples/**/*.yaml
!sdk/examples/**/*.py
!sdk/examples/**/*.sh
!sdk/examples/**/*.wav
!sdk/examples/**/Makefile
!sdk/examples/**/go.mod
!sdk/examples/**/go.sum
!sdk/examples/**/


runtime/test_output.txt


docs/linkinator-report.json


# GitHub Actions test artifacts
.github/actions/*/coverage/
.github/actions/*/junit.xml

# Example test outputs (generated by local testing)
examples/*/action-out/
examples/*/test-out/

# SDK E2E test results
sdk/e2e-results/

# Benchmark results
benchmarks/results/*.json
benchmarks/results/*.csv
benchmarks/results/*.md
