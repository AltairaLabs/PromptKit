output/
results/
reports/
*.html
out/
iot-maintenance-demo/
examples/my-demo-project/

# Logs
*.log
logs/

# Environment files
.env
.env.local
.env.demo

# Demo recordings
*.cast

# Temporary files
tmp/
temp/
*.tmp
.cache/
.gocache/
