{
  "$schema": "https://promptpack.org/schema/latest/promptpack.schema.json",
  "id": "runtime-config-example",
  "name": "Runtime Config Example",
  "version": "1.0.0",
  "description": "Customer support agent with external tools, evals, and hooks",
  "template_engine": {
    "version": "v1",
    "syntax": "{{variable}}"
  },
  "tools": {
    "sentiment_analysis": {
      "name": "sentiment_analysis",
      "description": "Analyze the sentiment of a text passage",
      "parameters": {
        "type": "object",
        "properties": {
          "text": {
            "type": "string",
            "description": "The text to analyze"
          }
        },
        "required": ["text"]
      }
    }
  },
  "evals": [
    {
      "id": "tone-check",
      "type": "tone_check",
      "trigger": "every_turn",
      "params": {
        "expected_tone": "professional"
      },
      "metric": {
        "name": "tone_score",
        "type": "gauge"
      }
    },
    {
      "id": "response-quality",
      "type": "response_quality",
      "trigger": "every_turn",
      "params": {
        "min_words": 5,
        "max_words": 500
      },
      "metric": {
        "name": "quality_score",
        "type": "gauge"
      }
    }
  ],
  "prompts": {
    "support": {
      "id": "support",
      "name": "Customer Support",
      "version": "1.0.0",
      "system_template": "You are a professional customer support agent for {{company_name}}. Be helpful, empathetic, and concise. Use the sentiment_analysis tool when you need to gauge customer mood.",
      "tools": ["sentiment_analysis"],
      "variables": [
        {
          "name": "company_name",
          "type": "string",
          "required": true,
          "description": "Company name"
        }
      ]
    }
  }
}
