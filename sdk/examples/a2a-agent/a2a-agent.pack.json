{
  "$schema": "https://promptpack.org/schema/latest/promptpack.schema.json",
  "id": "a2a-agent-example",
  "name": "A2A Agent Example",
  "version": "1.0.0",
  "description": "Demonstrates A2A agent integration with authentication via the SDK",
  "template_engine": {
    "version": "v1",
    "syntax": "{{variable}}"
  },
  "compilation": {
    "compiled_with": "hand-authored",
    "created_at": "2026-03-09T00:00:00Z",
    "schema": "v1"
  },
  "prompts": {
    "assistant": {
      "id": "assistant",
      "name": "A2A Assistant",
      "version": "1.0.0",
      "system_template": "You are {{assistant_role}} that can delegate tasks to remote A2A agents. Use the echo agent to echo messages back to the user.",
      "variables": [
        {
          "name": "assistant_role",
          "type": "string",
          "required": false,
          "default": "a helpful assistant",
          "description": "Role description for the assistant"
        }
      ]
    }
  }
}
