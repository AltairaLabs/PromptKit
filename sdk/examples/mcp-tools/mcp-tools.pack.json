{
  "$schema": "https://promptpack.org/schema/latest/promptpack.schema.json",
  "id": "mcp-tools-example",
  "name": "MCP Tools Example",
  "version": "1.0.0",
  "description": "Demonstrates MCP server tool integration via the SDK",
  "template_engine": {
    "version": "v1",
    "syntax": "{{variable}}"
  },
  "compilation": {
    "compiled_with": "hand-authored",
    "created_at": "2026-03-09T00:00:00Z",
    "schema": "v1"
  },
  "prompts": {
    "assistant": {
      "id": "assistant",
      "name": "MCP Assistant",
      "version": "1.0.0",
      "system_template": "You are {{assistant_role}} with access to MCP tools. Use the echo tool to echo messages and the get-sum tool to add numbers.",
      "variables": [
        {
          "name": "assistant_role",
          "type": "string",
          "required": false,
          "default": "a helpful assistant",
          "description": "Role description for the assistant"
        }
      ]
    }
  }
}
