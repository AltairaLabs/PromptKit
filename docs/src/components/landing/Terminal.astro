---
// On-brand static terminal. Color rides the glyph — no background fills.
// Title bar: two dim dots + one violet dot (PromptKit's accent; gold is
// reserved for the masterbrand).
---

<div class="term">
  <div class="bar">
    <span class="dot dim"></span>
    <span class="dot dim"></span>
    <span class="dot accent"></span>
    <span class="title">app.go · promptkit/sdk</span>
  </div>
  <pre class="body"><code><span class="prompt">~ ❯</span> <span class="cmd">go run</span> <span class="path">.</span>
<span class="ok">✓</span> <span class="out">opened conversation · pack "chat"</span>
<span class="out">streaming · first chunk 41ms · 0 dropped</span>
<span class="prompt">~ ❯</span> <span class="cmd">curl</span> <span class="path">:9090/metrics</span> <span class="flag">| grep promptkit_</span>
<span class="out">promptkit_inflight_streams 2000</span>
<span class="out">promptkit_first_chunk_ms_p50 41</span>
<span class="comment"># flat under load</span><span class="cursor"> </span></code></pre>
</div>

<style>
  .term {
    background: var(--surface-code);
    border: 1px solid var(--hairline);
    border-radius: var(--radius-code);
    overflow: hidden;
    box-shadow: var(--shadow-card);
  }
  .bar {
    display: flex;
    align-items: center;
    gap: 7px;
    padding: 11px 14px;
    border-bottom: 1px solid var(--hairline-faint);
  }
  .dot {
    width: 9px;
    height: 9px;
    border-radius: 50%;
  }
  .dot.dim {
    background: var(--star-dim);
  }
  .dot.accent {
    background: var(--nebula-violet);
  }
  .title {
    margin-left: 6px;
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--star-800);
  }
  .body {
    margin: 0;
    padding: 16px 18px;
    font-family: var(--font-mono);
    font-size: 12.5px;
    line-height: 1.75;
    white-space: pre;
    overflow-x: auto;
  }
  .prompt {
    color: var(--nebula-violet);
  }
  .cmd {
    color: var(--star-100);
  }
  .path {
    color: var(--starlight-200);
  }
  .flag {
    color: var(--star-700);
  }
  .out {
    color: var(--star-400);
  }
  .ok {
    color: var(--pulsar-300);
  }
  .comment {
    color: var(--star-950);
  }
  .cursor {
    display: inline-block;
    width: 8px;
    height: 1.05em;
    margin-left: 2px;
    vertical-align: text-bottom;
    background: var(--nebula-violet);
    animation: atlas-blink 1s steps(1) infinite;
  }
  @keyframes atlas-blink {
    0%,
    49% {
      opacity: 1;
    }
    50%,
    100% {
      opacity: 0;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .cursor {
      animation: none;
    }
  }
</style>
