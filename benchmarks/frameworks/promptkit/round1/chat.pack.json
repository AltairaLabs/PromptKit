{
  "$schema": "https://promptpack.org/schema/latest/promptpack.schema.json",
  "id": "benchmark-chat",
  "name": "Benchmark Chat",
  "version": "1.0.0",
  "description": "Minimal chat pack for streaming benchmark",
  "template_engine": {
    "version": "v1",
    "syntax": "{{variable}}"
  },
  "prompts": {
    "chat": {
      "id": "chat",
      "name": "Chat",
      "version": "1.0.0",
      "system_template": "You are a helpful assistant.",
      "parameters": {
        "max_tokens": 256,
        "temperature": 0.7
      }
    }
  }
}
